# Copy this file to `.env.local` and fill in the values.

# Google Apps Script Web App URL that appends booking & contact submissions
# to your Google Sheet. See Code.gs and the README for setup steps.
NEXT_PUBLIC_BOOKING_SCRIPT_URL=

# Public site origin, used for canonical URLs, sitemap.xml and robots.txt.
# e.g. https://www.mendlab.eg
NEXT_PUBLIC_SITE_URL=
