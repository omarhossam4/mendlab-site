# Copy this file to `.env.local` and fill in the values, then restart `npm run dev`.

# Google Apps Script Web App URL that appends booking & contact submissions
# to your Google Sheet. The site posts to it from a server route (/api/submit),
# so this can stay server-only (no NEXT_PUBLIC_ prefix needed).
# See Code.gs and the README for step-by-step setup.
BOOKING_SCRIPT_URL=

# Public site origin, used for canonical URLs, sitemap.xml and robots.txt.
# e.g. https://www.mendlab.eg
NEXT_PUBLIC_SITE_URL=
